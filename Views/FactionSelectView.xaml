<Page x:Class="BMS.ControlPanel.Views.FactionSelectView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        Title="Select Faction" Background="Transparent" Foreground="White">
                <Grid Background="{StaticResource PanelBrush}">
        <!-- Main Content -->
                                <Border Style="{StaticResource CpCardBorderStyle}" Width="460"
                                                                VerticalAlignment="Center" HorizontalAlignment="Center" Margin="24">
                                <StackPanel x:Name="MainPanel">
                                                <TextBlock Text="BMS Control Panel" FontSize="22"
                                                                                         FontWeight="Bold" Margin="0,0,0,10" Foreground="{StaticResource GoldTextBrush}"/>
                                                <TextBlock Text="Select or Create a Faction" FontSize="14"
                                                                                         Margin="0,0,0,20" Foreground="#A0A0A0"/>

            <!-- Faction List -->
            <TextBlock Text="Join Existing Faction" Foreground="White" Margin="0,0,0,8" FontWeight="Bold"/>
            <ListBox x:Name="FactionsListBox" Height="120" Margin="0,0,0,10"
                     Background="#0A0A0A" Foreground="#D8D8D8" BorderBrush="#2A2A2A" BorderThickness="1"
                     DisplayMemberPath="Title"
                     SelectionChanged="OnFactionSelected"/>

            <TextBlock Text="Officer Password" Foreground="White" Margin="0,0,0,5" FontSize="12"/>
            <PasswordBox x:Name="OfficerPasswordBox" Margin="0,0,0,10"
                         Style="{StaticResource CpInputPasswordBoxStyle}"/>

            <Button Content="Join Faction" Click="OnJoinFaction_Click" Margin="0,0,0,20"
                    Style="{StaticResource CpGoldButtonStyle}"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"/>

            <Separator Background="#2A2A2A" Margin="0,10"/>

            <!-- Create New Faction -->
            <TextBlock Text="Create New Faction" Foreground="White" Margin="0,15,0,8" FontWeight="Bold"/>
            <Button Content="Create Faction" Click="OnShowCreateDialog_Click"
                                        Style="{StaticResource CpSuccessButtonStyle}"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"/>
            <TextBlock Text="(Limited to 1 faction per account)" Foreground="#6A6A6A" Margin="0,8,0,0" FontSize="11"/>
        </StackPanel>
                </Border>

        <!-- Create Faction Dialog (overlay) -->
                <Border x:Name="CreateDialog" Background="#88000000" Padding="30"
                Visibility="{Binding ShowCreateFactionDialog, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Border Style="{StaticResource CpCardBorderStyle}" Width="460" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel>
                <TextBlock Text="Create New Faction" FontSize="20" FontWeight="Bold" 
                                                   Foreground="{StaticResource GoldTextBrush}" Margin="0,0,0,20"/>

                <TextBlock Text="Faction Name" Foreground="White" Margin="0,0,0,5"/>
                                <TextBox x:Name="FactionNameBox" Style="{StaticResource CpInputTextBoxStyle}" Margin="0,0,0,10"
                         Text="{Binding NewFactionName, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Officer Password (for joining via Control Panel)" 
                           Foreground="White" Margin="0,0,0,5" FontSize="12"/>
                                <PasswordBox x:Name="CreateOfficerPwBox" Style="{StaticResource CpInputPasswordBoxStyle}" Margin="0,0,0,10"/>

                <TextBlock Text="View Password (for viewing orders in BMS Overlay)" 
                           Foreground="White" Margin="0,0,0,5" FontSize="12"/>
                                <PasswordBox x:Name="CreateViewPwBox" Style="{StaticResource CpInputPasswordBoxStyle}" Margin="0,0,0,10"/>

                <TextBlock Text="Default Role Name" Foreground="White" Margin="0,0,0,5" FontSize="12"/>
                                <TextBox x:Name="DefaultRoleBox" Style="{StaticResource CpInputTextBoxStyle}" Margin="0,0,0,20"
                         Text="{Binding DefaultRoleName, UpdateSourceTrigger=PropertyChanged}"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Click="OnCancelCreate_Click" Margin="0,0,10,0"
                                                        Style="{StaticResource CpDarkButtonStyle}"/>
                    <Button Content="Create" Click="OnCreateFaction_Click"
                                                        Style="{StaticResource CpSuccessButtonStyle}"
                            IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"/>
                </StackPanel>
            </StackPanel>
                        </Border>
        </Border>

        <!-- Status Message -->
        <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Bottom"
                   HorizontalAlignment="Center" Margin="20" Foreground="#B8860B"
                   TextAlignment="Center" TextWrapping="Wrap" FontSize="13"
                   Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
    </Grid>
</Page>
