<Page x:Class="BMS.ControlPanel.Views.OrdersEditorView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            Title="BMS Orders Editor" Background="Transparent" Foreground="White">
        <DockPanel Margin="10" Background="Transparent">
        <!-- Top Navigation -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <Button Content="Delete" Click="OnDeleteOrder_Click" DockPanel.Dock="Right"
                Style="{StaticResource CpDangerButtonStyle}" Margin="5,0,0,0"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"/>
            <StackPanel Orientation="Horizontal">
                <Button Content="&#x25C0;" Width="40" Margin="0,0,5,0"
                Click="OnPrevOrder_Click" Style="{StaticResource CpDarkButtonStyle}"
                        FontSize="14"/>
                <TextBlock Text="{Binding OrderLabel}" VerticalAlignment="Center"
                           Foreground="White" Margin="10,0" FontSize="13"/>
                <Button Content="&#x25B6;" Width="40" Margin="5,0,0,0"
                Click="OnNextOrder_Click" Style="{StaticResource CpDarkButtonStyle}"
                        FontSize="14"/>
                <Button Content="+ New Order" Margin="20,0,0,0" Click="OnNewOrder_Click"
                Style="{StaticResource CpSuccessButtonStyle}" FontWeight="Bold"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"/>
            </StackPanel>
        </DockPanel>
        
        <!-- Title Input -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <TextBlock Text="Order Title" Foreground="#A0A0A0" Margin="0,0,0,4" FontSize="12"/>
            <TextBox x:Name="TitleBox" Style="{StaticResource CpInputTextBoxStyle}" FontSize="14"/>
        </StackPanel>

        <!-- Role Selector -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <TextBlock Text="Assign to Role (optional - blank means all roles can see)" Foreground="#A0A0A0" Margin="0,0,0,4" FontSize="12"/>
            <ComboBox ItemsSource="{Binding Roles}" SelectedItem="{Binding SelectedRole}"
                      DisplayMemberPath="Name" Style="{StaticResource CpComboBoxStyle}" FontSize="14">
                <ComboBox.ItemContainerStyle>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#D8D8D8"/>
                        <Setter Property="Background" Value="#0A0A0A"/>
                    </Style>
                </ComboBox.ItemContainerStyle>
            </ComboBox>
        </StackPanel>

        <!-- Map Image URL -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <TextBlock Text="Map Image URL (shared map for real-time drawing sync — paste a public image URL)" Foreground="#A0A0A0" Margin="0,0,0,4" FontSize="12"/>
            <TextBox x:Name="MapImageUrlBox" Text="{Binding MapImageUrl, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource CpInputTextBoxStyle}" FontSize="13"
                     ToolTip="Paste a publicly accessible image URL (e.g. Discord CDN, Imgur). All clients will load this map automatically."/>
        </StackPanel>

        <!-- Formatting Toolbar (applies to active text section) -->
        <Border DockPanel.Dock="Top" Background="#0A0A0A" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="0"
            Padding="6,4" Margin="0,0,0,8">
            <WrapPanel>
                <Button x:Name="BoldBtn" Content="B" Click="OnBold_Click" Width="32" Height="28" Margin="0,0,3,0"
                Style="{StaticResource CpDarkButtonStyle}" FontWeight="Bold" FontSize="13"/>
                <Button x:Name="ItalicBtn" Content="I" Click="OnItalic_Click" Width="32" Height="28" Margin="0,0,3,0"
                Style="{StaticResource CpDarkButtonStyle}" FontStyle="Italic" FontSize="13"/>
                <Button x:Name="UnderlineBtn" Content="U" Click="OnUnderline_Click" Width="32" Height="28" Margin="0,0,3,0"
                Style="{StaticResource CpDarkButtonStyle}" FontSize="13">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <TextBlock Text="U" TextDecorations="Underline"/>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>
                <Button x:Name="StrikeBtn" Content="S" Click="OnStrikethrough_Click" Width="32" Height="28" Margin="0,0,3,0"
                    Style="{StaticResource CpDarkButtonStyle}" FontSize="13">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <TextBlock Text="S" TextDecorations="Strikethrough"/>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>
                <Separator Width="1" Background="#2A2A2A" Margin="6,2"/>
                <Button Content="&#x2022; Bullets" Click="OnBulletList_Click" Height="28" Margin="0,0,3,0"
                    Style="{StaticResource CpDarkButtonStyle}" Padding="8,2" FontSize="12"/>
                <Button Content="1. Numbers" Click="OnNumberedList_Click" Height="28" Margin="0,0,3,0"
                    Style="{StaticResource CpDarkButtonStyle}" Padding="8,2" FontSize="12"/>
                <Separator Width="1" Background="#2A2A2A" Margin="6,2"/>
                <Button Content="&#x2191; Size" Click="OnIncreaseFontSize_Click" Height="28" Margin="0,0,3,0"
                    Style="{StaticResource CpDarkButtonStyle}" Padding="8,2" FontSize="12"/>
                <Button Content="&#x2193; Size" Click="OnDecreaseFontSize_Click" Height="28"
                    Style="{StaticResource CpDarkButtonStyle}" Padding="8,2" FontSize="12"/>
            </WrapPanel>
        </Border>
        
        <!-- Status Bar + Publish buttons at bottom -->
        <DockPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <TextBlock x:Name="PublishStatusLabel" Text="" Foreground="#60FF60"
                           VerticalAlignment="Center" Margin="0,0,15,0" FontSize="12"/>
                <Button Content="Save Draft" Click="OnSaveDraft_Click" Margin="0,0,8,0"
                    Style="{StaticResource CpDarkButtonStyle}" FontSize="13"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"/>
                <Button Content="Publish" Click="OnPublish_Click"
                    Style="{StaticResource CpSuccessButtonStyle}" FontWeight="Bold" FontSize="13"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"/>
            </StackPanel>
            <TextBlock Text="{Binding StatusMessage}" Foreground="#B8860B"
                       VerticalAlignment="Center" TextWrapping="Wrap" FontSize="12"
                       Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
        </DockPanel>
        
        <!-- Add Section Buttons at bottom of scrollable area -->
        <DockPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <TextBlock Text="Add Section:" Foreground="#A0A0A0" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
            <StackPanel Orientation="Horizontal">
                <Button Content="+ Text" Click="OnAddTextSection_Click" Margin="0,0,6,0"
                    Style="{StaticResource CpDarkButtonStyle}" FontSize="12"/>
                <Button Content="+ Image" Click="OnAddImageSection_Click" Margin="0,0,6,0"
                    Style="{StaticResource CpDarkButtonStyle}" FontSize="12"/>
                <Button Content="+ Video" Click="OnAddVideoSection_Click" Margin="0,0,6,0"
                    Style="{StaticResource CpDarkButtonStyle}" FontSize="12"/>
                <Button Content="+ Poll" Click="OnAddPollSection_Click" Margin="0,0,6,0"
                    Style="{StaticResource CpDarkButtonStyle}" FontSize="12"/>
                <Button Content="+ VC Roster" Click="OnAddVcRosterSection_Click" Margin="0,0,6,0"
                    Style="{StaticResource CpDarkButtonStyle}" FontSize="12"/>
                <Button Content="+ Checklist" Click="OnAddChecklistSection_Click"
                    Style="{StaticResource CpSuccessButtonStyle}" FontSize="12"/>
            </StackPanel>
        </DockPanel>
        
        <!-- Sections Editor (fills remaining space) -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Objectives Editor -->
                <Border Background="#0A0F0A" BorderBrush="#2A3A2A" BorderThickness="1"
                        CornerRadius="4" Margin="0,0,0,12" Padding="8">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,6">
                            <Button Content="+ Add Objective" Click="OnAddObjective_Click" DockPanel.Dock="Right"
                                    Style="{StaticResource CpDarkButtonStyle}" FontSize="12" Height="32" Padding="8,4"/>
                            <TextBlock Text="MISSION OBJECTIVES" Foreground="#B8D4B8"
                                       FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                        </DockPanel>
                        <StackPanel x:Name="ObjectivesPanel"/>
                    </StackPanel>
                </Border>
                <!-- Sections Editor -->
                <StackPanel x:Name="SectionsPanel"/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Page>
