<Page x:Class="BMS.ControlPanel.Views.VcRosterView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="VC Roster" Background="Transparent" Foreground="White">
    <DockPanel Margin="10" Background="Transparent">
        <TextBlock DockPanel.Dock="Top" FontSize="18"
                   FontWeight="Bold" Margin="0,0,0,10" Foreground="White">
            <Run Text="VC Roster"/>
            <Run Text=" — " Foreground="#666666"/>
            <Run Text="{Binding ChannelName, Mode=OneWay}" Foreground="#B8860B"/>
        </TextBlock>

        <!-- Status bar -->
        <DockPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#B8860B" VerticalAlignment="Center"
                       FontSize="12"/>
        </DockPanel>

        <!-- Action buttons -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,8,0,8">
            <Button Content="Save All" Click="OnSaveAll_Click" Margin="0,0,8,0"
                    Style="{StaticResource CpGoldButtonStyle}" FontSize="12"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"/>
            <Button Content="Refresh" Click="OnRefresh_Click"
                    Style="{StaticResource CpDarkButtonStyle}" FontSize="12"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"/>
        </StackPanel>

        <!-- Roster Grid -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding ChannelGroups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Channel Header -->
                        <Border BorderBrush="#2A2A2A" BorderThickness="1" Background="#0A0A0A"
                                Padding="10" Margin="0,0,0,8">
                            <StackPanel>
                                <!-- Channel Name and Team Assignment -->
                                <DockPanel Margin="0,0,0,8">
                                    <TextBlock Text="{Binding ChannelName}" Foreground="#C8AA6E"
                                               FontWeight="Bold" FontSize="13" VerticalAlignment="Center"
                                               Margin="0,0,8,0" MinWidth="150"/>
                                    <TextBlock Text="Team:" Foreground="#B8860B" VerticalAlignment="Center"
                                               FontSize="11" Margin="0,0,4,0"/>
                                    <TextBox Text="{Binding TeamName, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource CpInputTextBoxStyle}"
                                             Width="120" FontSize="11" HorizontalAlignment="Left"/>
                                </DockPanel>
                                
                                <!-- Column Headers -->
                                <Grid Margin="0,4,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="" FontSize="10" Foreground="#999999"/>
                                    <TextBlock Grid.Column="1" Text="Name" FontSize="10" Foreground="#999999" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="2" Text="Team" FontSize="10" Foreground="#999999" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="3" Text="Callsign" FontSize="10" Foreground="#999999" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="4" Text="Role" FontSize="10" Foreground="#999999" FontWeight="Bold"/>
                                </Grid>

                                <!-- Members in this channel -->
                                <ItemsControl ItemsSource="{Binding Members}" Margin="0,4,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#0D0D0D" BorderBrush="#1A1A1A" BorderThickness="1"
                                                    Padding="8" Margin="0,0,0,4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="30"/>
                                                        <ColumnDefinition Width="120"/>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Hide Checkbox -->
                                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsHidden, UpdateSourceTrigger=PropertyChanged}"
                                                              VerticalAlignment="Center" Margin="0,0,4,0"/>

                                                    <!-- Display Name -->
                                                    <TextBlock Grid.Column="1" Text="{Binding DisplayName}"
                                                               Foreground="#D8D8D8" FontSize="11" VerticalAlignment="Center"/>

                                                    <!-- Team -->
                                                    <TextBox Grid.Column="2" Text="{Binding Team, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource CpInputTextBoxStyle}" FontSize="10" Margin="4,0,4,0"/>

                                                    <!-- Callsign -->
                                                    <TextBox Grid.Column="3" Text="{Binding Callsign, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource CpInputTextBoxStyle}" FontSize="10" Margin="4,0,4,0"/>

                                                    <!-- Role -->
                                                    <TextBox Grid.Column="4" Text="{Binding Role, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource CpInputTextBoxStyle}" FontSize="10" Margin="4,0,4,0"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Page>
