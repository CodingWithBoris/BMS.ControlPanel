<Page x:Class="BMS.ControlPanel.Views.UserSettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="User Settings" Background="Transparent" Foreground="White">
    <Grid Background="{StaticResource PanelBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel MaxWidth="600" HorizontalAlignment="Center" Margin="24">

                <!-- Header -->
                <TextBlock Text="User Settings" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource GoldTextBrush}" Margin="0,0,0,24"/>

                <!-- Account Info Card -->
                <Border Style="{StaticResource CpCardBorderStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Account" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource GoldTextBrush}" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Name: " Foreground="#6A6A6A" FontSize="13"/>
                            <TextBlock Text="{Binding Username}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Discord: " Foreground="#6A6A6A" FontSize="13"/>
                            <TextBlock Foreground="White" FontSize="13">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Not linked"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentUser.DiscordTag, Converter={StaticResource StringToVisibilityConverter}}" Value="Visible">
                                                <Setter Property="Text" Value="{Binding CurrentUser.DiscordTag}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- My Factions Card -->
                <Border Style="{StaticResource CpCardBorderStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock Text="My Factions" FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource GoldTextBrush}" VerticalAlignment="Center"/>
                            <Button Content="Refresh" Click="OnRefresh_Click" DockPanel.Dock="Right"
                                    Style="{StaticResource CpDarkButtonStyle}" Cursor="Hand" MinWidth="80"
                                    HorizontalAlignment="Right"/>
                        </DockPanel>
                        <TextBlock Text="These are all the factions you have access to. Click any faction to switch to it."
                                   Foreground="#6A6A6A" FontSize="12" Margin="0,0,0,12" TextWrapping="Wrap"/>

                        <!-- Faction List -->
                        <ItemsControl x:Name="FactionsList" ItemsSource="{Binding UserFactions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#141414" BorderBrush="#2A2A2A" BorderThickness="1"
                                            CornerRadius="0" Padding="12,10" Margin="0,0,0,6" Cursor="Hand"
                                            MouseLeftButtonUp="OnFactionItem_Click">
                                        <DockPanel>
                                            <Button Content="Switch" DockPanel.Dock="Right"
                                                    Style="{StaticResource CpGoldButtonStyle}" Cursor="Hand"
                                                    MinWidth="80" Click="OnSwitchFaction_Click"
                                                    Tag="{Binding}" VerticalAlignment="Center"/>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="Bold"
                                                           Foreground="White"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock Text="{Binding Roles.Count, StringFormat='{}{0} role(s)'}"
                                                               Foreground="#6A6A6A" FontSize="11"/>
                                                </StackPanel>
                                                <StackPanel Margin="0,8,0,0">
                                                    <TextBlock Text="Discord Server ID" Foreground="#9A9A9A" FontSize="11"/>
                                                    <DockPanel Margin="0,4,0,0">
                                                        <Button Content="Save"
                                                                DockPanel.Dock="Right"
                                                                Style="{StaticResource CpDarkButtonStyle}"
                                                                Cursor="Hand"
                                                                MinWidth="60"
                                                                Margin="8,0,0,0"
                                                                Click="OnSaveDiscordServerId_Click"
                                                                Tag="{Binding}"/>
                                                        <TextBox Text="{Binding DiscordServerId, UpdateSourceTrigger=PropertyChanged}"
                                                                 Style="{StaticResource CpInputTextBoxStyle}"/>
                                                    </DockPanel>
                                                    <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="#6A6A6A"
                                                               Text="{Binding IsBotInDiscordServer, StringFormat='Bot in server: {0}'}"/>
                                                    <TextBlock FontSize="11" Foreground="#B8860B"
                                                               Text="{Binding BotInviteMessage}"
                                                               Visibility="{Binding BotInviteMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Empty state -->
                        <TextBlock Text="You haven't joined any factions yet."
                                   Foreground="#6A6A6A" FontSize="13" Margin="0,8,0,0"
                                   Visibility="{Binding UserFactions.Count, Converter={StaticResource InverseBooleanConverter}}"/>
                    </StackPanel>
                </Border>

                <!-- Join / Create Section -->
                <Border Style="{StaticResource CpCardBorderStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Join or Create a Faction" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource GoldTextBrush}" Margin="0,0,0,12"/>
                        <TextBlock Text="Join an existing faction with an officer password, or create your own (limit 1 per account)."
                                   Foreground="#6A6A6A" FontSize="12" Margin="0,0,0,12" TextWrapping="Wrap"/>
                        <Button Content="Join or Create Faction" Click="OnJoinOrCreate_Click"
                                Style="{StaticResource CpGoldButtonStyle}" Cursor="Hand"
                                HorizontalAlignment="Left" MinWidth="180"/>
                    </StackPanel>
                </Border>

                <!-- Status Message -->
                <TextBlock Text="{Binding StatusMessage}" Foreground="#B8860B"
                           TextAlignment="Center" TextWrapping="Wrap" FontSize="13" Margin="0,8,0,0"
                           Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
