<Page x:Class="BMS.ControlPanel.Views.PersonnelView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            Title="Personnel Management" Background="Transparent" Foreground="White">
        <DockPanel Margin="10" Background="Transparent">
        <TextBlock DockPanel.Dock="Top" Text="Faction Officers" FontSize="18"
                   FontWeight="Bold" Margin="0,0,0,10" Foreground="White"/>

        <!-- Status bar -->
        <DockPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#B8860B" VerticalAlignment="Center"
                       Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}"
                       FontSize="12"/>
        </DockPanel>

        <!-- Action buttons (owner only) -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0"
                    Visibility="{Binding IsOwner, Converter={StaticResource BoolToVisibilityConverter}}">
            <Button Content="Toggle Active" Click="OnToggleActive_Click" Margin="0,0,8,0"
                Style="{StaticResource CpDarkButtonStyle}" FontSize="12"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"/>
            <Button Content="Remove Officer" Click="OnRemoveOfficer_Click" Margin="0,0,8,0"
                Style="{StaticResource CpDangerButtonStyle}" FontSize="12"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"/>
        </StackPanel>

        <!-- Officers Grid -->
        <DataGrid ItemsSource="{Binding Officers}" SelectedItem="{Binding SelectedOfficer}"
                  AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                  Style="{StaticResource CpDataGridStyle}">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource CpDataGridColumnHeaderStyle}"/>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell" BasedOn="{StaticResource CpDataGridCellStyle}"/>
            </DataGrid.CellStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="*"/>
                <DataGridTextColumn Header="Role" Binding="{Binding RoleName}" Width="120"/>
                <DataGridTextColumn Header="Joined" Binding="{Binding JoinedAt, StringFormat='{}{0:yyyy-MM-dd}'}" Width="100"/>
                <DataGridTextColumn Header="Last Change" Binding="{Binding LastBmsChange, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="140"/>
                <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="60"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Page>
