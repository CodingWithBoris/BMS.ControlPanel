<Page x:Class="BMS.ControlPanel.Views.RolesView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Roles Management" Background="Transparent" Foreground="White">
    
    <Grid Margin="10" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Faction Roles" FontSize="18"
                   FontWeight="Bold" Margin="0,0,0,10" Foreground="White"/>

        <!-- Roles Grid -->
        <DataGrid Grid.Row="1" ItemsSource="{Binding Roles}" SelectedItem="{Binding SelectedRole}"
                  AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                  Style="{StaticResource CpDataGridStyle}">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource CpDataGridColumnHeaderStyle}"/>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell" BasedOn="{StaticResource CpDataGridCellStyle}"/>
            </DataGrid.CellStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Role Name" Binding="{Binding Name}" Width="*"/>
                <DataGridCheckBoxColumn Header="Default" Binding="{Binding IsDefault}" Width="80"/>
                <DataGridCheckBoxColumn Header="Has Password" Binding="{Binding HasPassword}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="➕ Add Role" Click="OnAddRole_Click"
                Style="{StaticResource CpSuccessButtonStyle}" FontSize="12" Margin="0,0,8,0"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"/>
            <Button Content="✏️ Edit Role" Click="OnEditRole_Click"
                Style="{StaticResource CpDarkButtonStyle}" FontSize="12" Margin="0,0,8,0"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"/>
            <Button Content="🗑️ Delete Role" Click="OnDeleteRole_Click"
                Style="{StaticResource CpDangerButtonStyle}" FontSize="12"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"/>
        </StackPanel>

        <!-- Status Message -->
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" Foreground="#B8860B"
                   Margin="0,8,0,0" FontSize="12"/>

        <!-- Create Role Dialog -->
        <Border Grid.Row="0" Grid.RowSpan="4" Background="#80000000"
                Visibility="{Binding ShowCreateDialog, Converter={StaticResource BoolToVisibilityConverter}}"
                MouseDown="OnOverlay_MouseDown">
            <Border Background="#0A0A0A" Width="400" Height="300" CornerRadius="0"
                BorderBrush="#2A2A2A" BorderThickness="1">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Create New Role" FontSize="16" FontWeight="Bold" 
                               Foreground="{StaticResource GoldTextBrush}" Margin="0,0,0,15"/>

                    <TextBlock Grid.Row="1" Text="Role Name" Foreground="White" Margin="0,0,0,5"/>
                    <TextBox Grid.Row="2" Text="{Binding NewRoleName, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource CpInputTextBoxStyle}"
                             Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="3" Text="Password (optional)" Foreground="White" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="NewRolePasswordBox" Grid.Row="4" 
                                 Style="{StaticResource CpInputPasswordBoxStyle}"
                                 Margin="0,0,0,10" VerticalAlignment="Top"/>

                    <CheckBox Grid.Row="4" Content="Set as Default Role" 
                              IsChecked="{Binding NewRoleIsDefault}" 
                              Foreground="White" Margin="0,50,0,0" VerticalAlignment="Top"/>

                    <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="✓ Create" Click="OnCreateRole_Click"
                                Style="{StaticResource CpSuccessButtonStyle}" Width="90" Margin="0,0,8,0"/>
                        <Button Content="✕ Cancel" Click="OnCancelCreate_Click"
                                Style="{StaticResource CpDarkButtonStyle}" Width="90"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <!-- Edit Role Dialog -->
        <Border Grid.Row="0" Grid.RowSpan="4" Background="#80000000"
                Visibility="{Binding ShowEditDialog, Converter={StaticResource BoolToVisibilityConverter}}"
                MouseDown="OnOverlay_MouseDown">
            <Border Background="#0A0A0A" Width="400" Height="300" CornerRadius="0"
                BorderBrush="#2A2A2A" BorderThickness="1">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Edit Role" FontSize="16" FontWeight="Bold" 
                               Foreground="{StaticResource GoldTextBrush}" Margin="0,0,0,15"/>

                    <TextBlock Grid.Row="1" Text="Role Name" Foreground="White" Margin="0,0,0,5"/>
                    <TextBox Grid.Row="2" Text="{Binding EditRoleName, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource CpInputTextBoxStyle}"
                             Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="3" Text="New Password (leave empty to keep current)" Foreground="White" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="EditRolePasswordBox" Grid.Row="4" 
                                 Style="{StaticResource CpInputPasswordBoxStyle}"
                                 Margin="0,0,0,10" VerticalAlignment="Top"/>

                    <CheckBox Grid.Row="4" Content="Set as Default Role" 
                              IsChecked="{Binding EditRoleIsDefault}" 
                              Foreground="White" Margin="0,50,0,0" VerticalAlignment="Top"/>

                    <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="✓ Update" Click="OnUpdateRole_Click"
                                Style="{StaticResource CpSuccessButtonStyle}" Width="90" Margin="0,0,8,0"/>
                        <Button Content="✕ Cancel" Click="OnCancelEdit_Click"
                                Style="{StaticResource CpDarkButtonStyle}" Width="90"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Page>
