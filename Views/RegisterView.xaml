<Page x:Class="BMS.ControlPanel.Views.RegisterView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Register" Background="Transparent" Foreground="White">
    <Grid Background="{StaticResource PanelBrush}">
        <Border Style="{StaticResource CpCardBorderStyle}" Width="360"
                VerticalAlignment="Center" HorizontalAlignment="Center" Margin="24">
            <StackPanel>
                <TextBlock Text="Create Account" FontSize="22"
                           FontWeight="Bold" Margin="0,0,0,20" Foreground="{StaticResource GoldTextBrush}"/>

                <TextBlock Text="Username" Foreground="White" Margin="0,0,0,5"/>
                <TextBox x:Name="UsernameBox" Margin="0,0,0,8"
                         Style="{StaticResource CpInputTextBoxStyle}"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Password" Foreground="White" Margin="0,0,0,5"/>
                <PasswordBox x:Name="PasswordBox" Margin="0,0,0,8"
                             Style="{StaticResource CpInputPasswordBoxStyle}"/>

                <TextBlock Text="Confirm Password" Foreground="White" Margin="0,0,0,5"/>
                <PasswordBox x:Name="ConfirmPasswordBox" Margin="0,0,0,16"
                             Style="{StaticResource CpInputPasswordBoxStyle}"/>

                <Button Content="Create Account" Click="OnRegister_Click" Margin="0,0,0,8"
                        Style="{StaticResource CpGoldButtonStyle}"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"/>

                <TextBlock Text="{Binding StatusMessage}" Foreground="White"
                           TextWrapping="Wrap" Margin="0,0,0,12" MinHeight="30"
                           Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

                <TextBlock TextWrapping="Wrap" Foreground="White">
                    <Run Text="Already have an account? "/>
                    <Hyperlink NavigateUri="#" RequestNavigate="OnBackToLogin_Click" Foreground="{StaticResource GoldTextBrush}">
                        Back to Login
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Page>
